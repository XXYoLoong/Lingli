# 邻里后端环境配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
DEBUG=false
APP_NAME=邻里后端服务
APP_VERSION=1.0.0

# 数据库配置 (PostgreSQL)
DATABASE_URL=postgresql+psycopg2://neighbor:neighbor_password@localhost:5432/neighbor_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_TOKEN_EXPIRE=86400

# JWT 密钥 (生产环境必须使用强随机密钥)
SECRET_KEY=your-secret-key-change-in-production

# Qwen API 配置 (阿里云百炼)
DASHSCOPE_API_KEY=sk-your-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_DEFAULT=qwen-plus
QWEN_MODEL_REVIEW=qwen-plus
QWEN_MODEL_SUMMARY=qwen-flash
QWEN_TIMEOUT=30
QWEN_MAX_RETRIES=3

# 文件存储配置
UPLOAD_DIR=/opt/neighbor/uploads
MAX_UPLOAD_SIZE=10485760

# CORS 配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# 日志
LOG_LEVEL=INFO
